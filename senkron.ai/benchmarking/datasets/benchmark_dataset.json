    "e2e_tests": [
        {
            "test_id": "e2e_001",
            "scenario": "happy_path_simple_appointment",
            "input": "Kardiyoloji için randevu istiyorum",
            "expected_route": "APPT_CREATE",
            "expected_outcome": "success",
            "expected_tools_called": [
                "doctor.search",
                "appointment.find_slots",
                "appointment.create"
            ],
            "expected_response_contains": [
                "randevu",
                "oluşturuldu",
                "doktor"
            ],
            "description": "Standard appointment creation flow"
        },
        {
            "test_id": "e2e_002",
            "scenario": "edge_case_no_available_slots",
            "input": "Bugün kardiyoloji randevusu alabilir miyim?",
            "expected_route": "APPT_CREATE",
            "expected_outcome": "partial_success",
            "expected_tools_called": [
                "doctor.search",
                "appointment.find_slots"
            ],
            "expected_response_contains": [
                "müsait",
                "slot",
                "başka"
            ],
            "description": "Handles no available slots gracefully"
        },
