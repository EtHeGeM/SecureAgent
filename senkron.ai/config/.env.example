# Multi-Provider LLM System - Environment Variables

# ============================================
# ANTHROPIC (Claude)
# ============================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Get your key from: https://console.anthropic.com/

# ============================================
# OPENAI (GPT)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
# Get your key from: https://platform.openai.com/api-keys

# ============================================
# GOOGLE (Gemini)
# ============================================
GOOGLE_API_KEY=your_google_api_key_here
# Get your key from: https://ai.google.dev/

# ============================================
# GENERAL CONFIGURATION
# ============================================
DEFAULT_MAX_TOKENS=512
DEFAULT_TEMPERATURE=0.1
ENABLE_COST_TRACKING=true

# ============================================
# LOCAL MODEL SETTINGS
# ============================================
# Device to use for local models (cuda, cpu, auto)
LOCAL_DEVICE=auto

# Default quantization for local models
DEFAULT_QUANTIZATION=int4

# ============================================
# BENCHMARK SETTINGS
# ============================================
# Maximum cost per benchmark run (USD)
MAX_BENCHMARK_COST=10.0

# Save detailed logs
SAVE_DETAILED_LOGS=true

# Output directory
BENCHMARK_OUTPUT_DIR=benchmark_results
